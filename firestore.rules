rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper Functions ───────────────────────────────────────────────────

    /** Is the requester authenticated at all? */
    function isAuthenticated() {
      return request.auth != null;
    }

    /** Does the requester's token UID match the given userId? */
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    /** Is the requester the sole admin? */
    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == "marathivloggerstudio@gmail.com"
      );
    }

    /** 
     * Prevent any write from injecting a userId that differs from the
     * caller's own UID. This closes the "token mismatch" attack vector.
     */
    function ownershipMatchesAuth() {
      return !("userId" in request.resource.data) ||
             request.resource.data.userId == request.auth.uid;
    }

    /**
     * Prevent any write from injecting a clerkId that differs from the
     * caller's own UID (Clerk UIDs are stored as Firebase UIDs after sync).
     */
    function clerkIdMatchesAuth() {
      return !("clerkId" in request.resource.data) ||
             request.resource.data.clerkId == request.auth.uid;
    }

    // ── Users Collection ───────────────────────────────────────────────────
    // Each user document is keyed by their Clerk/Firebase UID.
    // Users can only read or write their OWN document.
    // Admins can read all.
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && clerkIdMatchesAuth();
      allow update: if isOwner(userId) && clerkIdMatchesAuth();
      allow delete: if isAdmin();
    }

    // ── Orders Collection ──────────────────────────────────────────────────
    // Users can create their OWN orders (userId must match their UID).
    // Users can read only their OWN orders.
    // Admins have full access.
    match /orders/{orderId} {
      allow create: if isAuthenticated() && ownershipMatchesAuth();
      allow read:   if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── Reviews Collection ─────────────────────────────────────────────────
    // Approved reviews are publicly readable.
    // Only authenticated users can submit their OWN review (userId must match).
    // Admins can moderate (update/delete).
    match /reviews/{reviewId} {
      allow read:   if resource.data.approved == true || isAdmin();
      allow create: if isAuthenticated() && ownershipMatchesAuth();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── Publicly Readable Media ────────────────────────────────────────────
    // Portfolio / service media: anyone can read, only admins can write.
    match /service_media/{mediaId} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // ── Audit Logs ─────────────────────────────────────────────────────────
    // Authenticated users can create their OWN audit entries (for client-side logging).
    // Only admins can read all logs.
    // Nobody (not even admins) can update or delete audit logs (immutable).
    match /audit_logs/{logId} {
      allow create: if isAuthenticated() && ownershipMatchesAuth();
      allow read:   if isAdmin();
      allow update: if false;
      allow delete: if false;
    }

    // ── Default Deny ───────────────────────────────────────────────────────
    // Any collection not explicitly listed above is fully denied for everyone.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
